#. Plugin Name of the plugin
#: cc-head-cleaner-and-speedup.php
msgid "CC Head Cleaner & Speed Up"
msgstr "CC 網站 Head 清理與加速"

#. Description of the plugin
#: cc-head-cleaner-and-speedup.php
msgid ""
"Clean WordPress head output and optionally disable selected features for a "
"lighter frontend."
msgstr "清理 WordPress head 輸出，並可選擇停用指定功能，讓前台更輕量。"

#. Author of the plugin
#: cc-head-cleaner-and-speedup.php
msgid "Chance Lin"
msgstr "C.C. Lin"

#. Author URI of the plugin
#: cc-head-cleaner-and-speedup.php
msgid "https://cclin.cc"
msgstr "https://cclin.cc"

#: cc-head-cleaner-and-speedup.php:34
msgid "Settings"
msgstr "設定"

#: includes/feature-toggle.php:76
msgid "Feeds are disabled."
msgstr "訂閱功能已停用。"

#: includes/settings-data.php:21
msgid "Remove"
msgstr "移除"

#: includes/settings-data.php:22
msgid "Clean head output"
msgstr "清理 head 輸出"

#: includes/settings-data.php:26
msgid "Remove WP Generator Version"
msgstr "移除 WordPress 版本資訊"

#: includes/settings-data.php:27
msgid "Removes the WordPress version meta tag for improved security."
msgstr "移除 WordPress 版本標籤以提升安全性。"

#: includes/settings-data.php:31
msgid "Remove Auto Sizes CSS Output"
msgstr "移除自動尺寸 CSS"

#: includes/settings-data.php:32
msgid "Removes inline CSS for responsive images."
msgstr "移除響應式圖片的內嵌 CSS 樣式。"

#: includes/settings-data.php:36
msgid "Remove RSD Link"
msgstr "移除 RSD 連結"

#: includes/settings-data.php:37
msgid "Removes Really Simple Discovery (RSD) link."
msgstr "移除 Really Simple Discovery (RSD) 探索連結。"

#: includes/settings-data.php:41
msgid "Remove WLW Manifest Link"
msgstr "移除 WLW 設定檔連結"

#: includes/settings-data.php:42
msgid "Removes Windows Live Writer manifest link."
msgstr "移除 Windows Live Writer 設定檔連結。"

#: includes/settings-data.php:46
msgid "Remove Shortlink"
msgstr "移除短網址"

#: includes/settings-data.php:47
msgid "Removes shortlink from head output and HTTP headers."
msgstr "從 head 輸出與 HTTP header 移除短網址。"

#: includes/settings-data.php:51
msgid "Remove Feed Links"
msgstr "移除 RSS 訂閱連結"

#: includes/settings-data.php:52
msgid "Removes RSS feed link tags."
msgstr "移除 RSS 訂閱連結標籤。"

#: includes/settings-data.php:56
msgid "Remove REST API Link"
msgstr "移除 REST API 連結"

#: includes/settings-data.php:57
msgid "Removes REST API discovery links from head output and HTTP headers."
msgstr "從 head 輸出與 HTTP header 移除 REST API discovery link。"

#: includes/settings-data.php:61
msgid "Remove oEmbed Discovery Links"
msgstr "移除 oEmbed 探索連結"

#: includes/settings-data.php:62
msgid "Removes oEmbed discovery links."
msgstr "移除 oEmbed 探索連結。"

#: includes/settings-data.php:66
msgid "Remove Rel Prev/Next Links"
msgstr "移除前後文章連結"

#: includes/settings-data.php:67
msgid "Removes adjacent posts relationship links."
msgstr "移除相鄰文章的前後連結。"

#: includes/settings-data.php:71
msgid "Remove XFN Profile Link"
msgstr "移除 XFN 個人檔案連結"

#: includes/settings-data.php:72
msgid "Removes rarely used XFN profile link."
msgstr "移除較少使用的 XFN 個人檔案連結。"

#: includes/settings-data.php:76
msgid "Remove DNS Prefetch"
msgstr "移除 DNS 預先解析"

#: includes/settings-data.php:77
msgid "Removes DNS prefetch links."
msgstr "移除 DNS 預先解析連結。"

#: includes/settings-data.php:81
msgid "Remove Emoji Output"
msgstr "移除 Emoji 輸出"

#: includes/settings-data.php:82
msgid "Removes emoji scripts and styles from head output."
msgstr "從 head 輸出移除 emoji 腳本與樣式。"

#: includes/settings-data.php:86
msgid "Remove Gutenberg Block CSS"
msgstr "移除 Gutenberg 區塊 CSS"

#: includes/settings-data.php:87
msgid "Removes block editor CSS from the frontend."
msgstr "從前台移除區塊編輯器的 CSS 樣式。"

#: includes/settings-data.php:91
msgid "Remove Gutenberg Theme Enhancements"
msgstr "移除 Gutenberg 佈景增強樣式"

#: includes/settings-data.php:92
msgid "Removes wp-block-library-theme CSS."
msgstr "移除 wp-block-library-theme CSS。"

#: includes/settings-data.php:96
msgid "Remove Global Styles Inline CSS"
msgstr "移除全域樣式內嵌 CSS"

#: includes/settings-data.php:97
msgid "Removes inline CSS generated from theme.json."
msgstr "移除 theme.json 生成的內嵌 CSS。"

#: includes/settings-data.php:101
msgid "Remove Classic Theme Styles"
msgstr "移除傳統佈景樣式"

#: includes/settings-data.php:102
msgid "Removes default classic theme compatibility styles."
msgstr "移除傳統佈景相容性樣式。"

#: includes/settings-data.php:107
msgid "Disable"
msgstr "停用"

#: includes/settings-data.php:108
msgid "Disable features"
msgstr "停用功能"

#: includes/settings-data.php:112
msgid "Disable Global Styles"
msgstr "停用全域樣式"

#: includes/settings-data.php:113
msgid ""
"Completely disables global style sheets and includes related head output "
"cleanup."
msgstr "完全停用全域樣式表，並包含相關的 head 輸出清理。"

#: includes/settings-data.php:117
msgid "Disable Image Auto Sizes CSS"
msgstr "停用圖片自動尺寸 CSS"

#: includes/settings-data.php:118
msgid ""
"Prevents automatic responsive image CSS and includes related head output "
"cleanup."
msgstr "防止自動生成響應式圖片 CSS，並包含相關的 head 輸出清理。"

#: includes/settings-data.php:122
msgid "Disable Block Editor"
msgstr "停用區塊編輯器"

#: includes/settings-data.php:123
msgid "Disables Gutenberg editor for posts and widgets."
msgstr "停用文章與小工具的 Gutenberg 區塊編輯器。"

#: includes/settings-data.php:127
msgid "Disable Emoji Scripts"
msgstr "停用 Emoji 腳本"

#: includes/settings-data.php:128
msgid ""
"Removes all emoji-related functionality and includes related head output "
"cleanup."
msgstr "移除所有 Emoji 相關功能，並包含相關的 head 輸出清理。"

#: includes/settings-data.php:132
msgid "Disable oEmbed Support"
msgstr "停用 oEmbed 支援"

#: includes/settings-data.php:133
msgid "Disables oEmbed API routes and includes related head output cleanup."
msgstr "停用 oEmbed API 路徑，並包含相關的 head 輸出清理。"

#: includes/settings-data.php:137
msgid "Disable All RSS Feed Routes"
msgstr "停用所有 RSS 訂閱路徑"

#: includes/settings-data.php:138
msgid "Completely disables RSS feeds and includes related head output cleanup."
msgstr "完全停用 RSS 訂閱功能，並包含相關的 head 輸出清理。"

#: includes/settings-data.php:142
msgid "Remove frontend jQuery Migrate"
msgstr "移除前台 jQuery Migrate"

#: includes/settings-data.php:143
msgid "Only removes frontend jQuery Migrate."
msgstr "只移除前台 jQuery Migrate。"

#: includes/settings-data.php:147
msgid "Remove all frontend jQuery"
msgstr "移除所有前台 jQuery"

#: includes/settings-data.php:148
msgid "Completely removes jQuery on the frontend."
msgstr "完整移除前台 jQuery。"

#: includes/settings-data.php:152
msgid "Remove comments and replies"
msgstr "移除留言與回覆"

#: includes/settings-data.php:153
msgid "Closes frontend comments and removes comment reply output."
msgstr "關閉前台留言並移除留言回覆輸出。"

#: includes/settings-data.php:215
msgid "Notes"
msgstr "說明"

#: includes/settings-page.php:16
msgid "Site Cleaner & Speed Up"
msgstr "CC 網站清理與加速"

#: includes/settings-page.php:17
msgid "Site Cleanup"
msgstr "CC 網站清理"

#: includes/settings-ui.php:15
msgid "Site Head Cleaner & Speed Up"
msgstr "CC 網站 Head 清理與加速"

